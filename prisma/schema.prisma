generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/// A league event (one per JustGo competition Thom played in)
model Event {
  id           String   @id // JustGo event ID, e.g. "55659"
  name         String
  eventDate    DateTime @map("event_date") @db.Date
  ratingBefore Int?     @map("rating_before")
  ratingAfter  Int      @map("rating_after")
  won          Int      @default(0)
  lost         Int      @default(0)
  scrapedAt    DateTime @default(now()) @map("scraped_at")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  matches Match[]

  @@index([eventDate])
  @@map("events")
}

/// An individual match result within an event
model Match {
  id           Int      @id @default(autoincrement())
  eventId      String   @map("event_id")
  event        Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  opponentName String   @map("opponent_name")
  thomSets     Int      @map("thom_sets")
  opponentSets Int      @map("opponent_sets")
  scoreString  String   @map("score_string") // e.g. "3-1", kept for posterity
  thomWon      Boolean  @map("thom_won")
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([eventId])
  @@index([opponentName])
  @@map("matches")
}
